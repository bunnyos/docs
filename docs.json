{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "bunnyOS",
  "description": "Guides for using bunnyOS: chat privately with bunny, give it tools and apps, and earn Carrots by contributing compute or staking OS.",
  "colors": {
    "primary": "#2962FF",
    "light": "#5B82FF",
    "dark": "#1E4FD6"
  },
  "favicon": "/favicon.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "tabs": [
      {
        "tab": "User Guide",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "user/getting-started/introduction",
              "user/getting-started/sign-in"
            ]
          },
          {
            "group": "Chatting with bunny",
            "icon": "message-circle",
            "expanded": true,
            "pages": [
              "user/chat/chat-intro",
              "user/chat/on-device-vs-cloud",
              "user/chat/built-in-tools",
              "user/chat/connectors-and-servers",
              "user/chat/permissions",
              "user/chat/memory"
            ]
          },
          {
            "group": "bunnyApps",
            "icon": "layout-grid",
            "pages": [
              "user/apps/app-store"
            ]
          },
          {
            "group": "Community & devices",
            "icon": "sparkles",
            "pages": [
              "user/community/generate-images",
              "user/community/bunny-b1"
            ]
          },
          {
            "group": "Carrots & OS",
            "icon": "carrot",
            "pages": [
              "user/carrots/explained",
              "user/carrots/your-carrots",
              "user/carrots/stake-os"
            ]
          },
          {
            "group": "Contribute compute",
            "icon": "cpu",
            "pages": [
              "user/compute/overview",
              "user/compute/browser-worker",
              "user/compute/native-worker"
            ]
          }
        ]
      },
      {
        "tab": "Whitepaper",
        "icon": "scroll-text",
        "href": "https://bunnyos.ai/litepaper"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Launch app",
      "href": "https://platform.bunnyos.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/officialbunnyos"
    }
  }
}
